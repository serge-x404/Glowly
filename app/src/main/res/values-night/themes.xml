<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SkinCare" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary -->
        <item name="colorPrimary">@color/md_theme_green_50</item>
        <item name="colorOnPrimary">@color/md_theme_neutral_100</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/md_theme_brown_50</item>
        <item name="colorOnSecondary">@color/md_theme_neutral_100</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/md_theme_neutral_100</item>

        <!-- Surface -->
        <item name="colorSurface">@color/md_theme_neutral_90</item>
        <item name="colorOnSurface">@color/md_theme_neutral_10</item>

        <!-- Surface Variant -->
        <item name="colorSurfaceVariant">@color/md_theme_neutral_80</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_neutral_40</item>

        <!-- Outline -->
        <item name="colorOutline">@color/md_theme_neutral_60</item>

    </style>
</resources>