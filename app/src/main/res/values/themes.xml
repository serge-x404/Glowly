<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SkinCare" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary -->
        <item name="colorPrimary">@color/md_theme_green_40</item>
        <item name="colorOnPrimary">@color/md_theme_neutral_10</item>
        <item name="colorPrimaryContainer">@color/md_theme_green_50</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_neutral_100</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/md_theme_brown_60</item>
        <item name="colorOnSecondary">@color/md_theme_neutral_10</item>
        <item name="colorSecondaryContainer">@color/md_theme_brown_40</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_neutral_100</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/md_theme_green_40</item>
        <item name="colorOnTertiary">@color/md_theme_neutral_100</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/md_theme_neutral_10</item>

        <!-- Surface -->
        <item name="colorSurface">@color/md_theme_neutral_10</item>
        <item name="colorOnSurface">@color/md_theme_neutral_90</item>

        <!-- Surface Variant -->
        <item name="colorSurfaceVariant">@color/md_theme_neutral_30</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_neutral_70</item>

        <!-- Outline -->
        <item name="colorOutline">@color/md_theme_neutral_50</item>

        <!-- Status/Nav Bar -->
        <item name="android:statusBarColor">
            @android:color/transparent
        </item>

        <item name="android:navigationBarColor">
            @android:color/transparent
        </item>

    </style>

    <style name="Theme.SkinCare" parent="Base.Theme.SkinCare" />
</resources>