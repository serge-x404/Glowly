<!-- typography.xml -->

<resources>

    <style name="TextAppearance.Aurea.DisplayLarge">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">48sp</item>
        <item name="android:lineHeight">58sp</item>
        <item name="android:textFontWeight">700</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <style name="TextAppearance.Aurea.DisplayMedium">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">42sp</item>
        <item name="android:lineHeight">53sp</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <style name="TextAppearance.Aurea.DisplaySmall">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">36sp</item>
        <item name="android:lineHeight">46sp</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <!-- ========================================================= -->
    <!-- HEADLINE -->
    <!-- ========================================================= -->

    <style name="TextAppearance.Aurea.HeadlineLarge">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">32sp</item>
        <item name="android:lineHeight">40sp</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <style name="TextAppearance.Aurea.HeadlineMedium">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">28sp</item>
        <item name="android:lineHeight">36sp</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <style name="TextAppearance.Aurea.HeadlineSmall">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">24sp</item>
        <item name="android:lineHeight">32sp</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <!-- ========================================================= -->
    <!-- TITLE -->
    <!-- ========================================================= -->

    <style name="TextAppearance.Aurea.TitleLarge">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">22sp</item>
        <item name="android:lineHeight">28sp</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <style name="TextAppearance.Aurea.TitleMedium">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">18sp</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <style name="TextAppearance.Aurea.TitleSmall">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">22sp</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <!-- ========================================================= -->
    <!-- BODY -->
    <!-- ========================================================= -->

    <style name="TextAppearance.Aurea.BodyLarge">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.Aurea.BodyMedium">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">21sp</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.Aurea.BodySmall">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineHeight">18sp</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <!-- ========================================================= -->
    <!-- LABEL -->
    <!-- ========================================================= -->

    <style name="TextAppearance.Aurea.LabelLarge">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <style name="TextAppearance.Aurea.LabelMedium">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight">16sp</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <style name="TextAppearance.Aurea.LabelSmall">
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textSize">11sp</item>
        <item name="android:lineHeight">14sp</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

</resources>